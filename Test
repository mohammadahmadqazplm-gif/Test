local function safeTeleport(targetCFrame)
    local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
    if not root then return false end
    local dist = (targetCFrame.Position - root.Position).Magnitude
    if dist > 500 then
        local mid = CFrame.new(root.Position:Lerp(targetCFrame.Position, 0.5)) + Vector3.new(0, 5, 0)
        pcall(function() root.CFrame = mid end)
        task.wait(0.08)
    end
    local ok = pcall(function() root.CFrame = targetCFrame end)
    if not ok then
        pcall(function()
            local tw = TweenService:Create(root, TweenInfo.new(0.12, Enum.EasingStyle.Linear), { CFrame = targetCFrame })
            tw:Play()
            tw.Completed:Wait()
        end)
    end
    return true
end

