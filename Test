local function buyGear(gearKey)
    local data = GEAR_REGISTRY[gearKey]
    if not data then return BUY_RESULT.NOT_IN_SHOP end

    local remote = ReplicatedStorage.Events.VendorPurchase

    -- نشوف عدد الـ Tools قبل
    local backpack    = player:FindFirstChild("Backpack")
    local toolsBefore = {}
    if backpack then
        for _, v in pairs(backpack:GetChildren()) do
            if v:IsA("Tool") then toolsBefore[v] = true end
        end
    end

    -- نصفر الـ notification ونبعث
    lastNotification = ""
    pcall(function() remote:FireServer(data.serverKey) end)

    -- ننتظر رد الـ server (notification أو tool جديد)
    local waited = 0
    while waited < 1.5 do
        task.wait(0.1)
        waited = waited + 0.1
        if lastNotification ~= "" then break end
        -- نشوف لو جاء tool جديد
        if backpack then
            for _, v in pairs(backpack:GetChildren()) do
                if v:IsA("Tool") and not toolsBefore[v] then
                    Rayfield:Notify({ Title = "✅ تم الشراء!", Content = data.displayName, Duration = 3, Image = 4483362458 })
                    return BUY_RESULT.SUCCESS
                end
            end
        end
    end

    -- نحلل الـ notification
    local notif = lastNotification:lower()

    if notif:find("out of stock") or notif:find("stock") then
        return BUY_RESULT.OUT_OF_STOCK
    elseif notif:find("not enough") or notif:find("afford") or notif:find("coins") then
        return BUY_RESULT.NO_COINS
    end

    -- تأكيد أخير — tool جديد؟
    if backpack then
        for _, v in pairs(backpack:GetChildren()) do
            if v:IsA("Tool") and not toolsBefore[v] then
                Rayfield:Notify({ Title = "✅ تم الشراء!", Content = data.displayName, Duration = 3, Image = 4483362458 })
                return BUY_RESULT.SUCCESS
            end
        end
    end

    return BUY_RESULT.NOT_IN_SHOP
end

