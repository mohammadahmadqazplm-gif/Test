-- يرجع: "active" + secondsLeft، أو "queued" + secondsUntilStart، أو nil
local function getCoinRainStatus()
    local ok, etc = pcall(function()
        return require(game:GetService("ReplicatedStorage").Modules.EventTimerController)
    end)
    if not ok or not etc or not etc.OnGoingTimers then return nil end

    -- نشيل الـ HTML tags من النص
    local function stripTags(s)
        return tostring(s):gsub("<[^>]+>", ""):gsub("&lt;", "<"):gsub("&gt;", ">")
    end

    for _, timer in pairs(etc.OnGoingTimers) do
        local ui = timer.UI
        if typeof(ui) ~= "Instance" then continue end
        local timeLeft = tonumber(timer.TimeRemaining) or 0

        -- event شغال الحين (E-*) — nameLabel
        local nameLabel = ui:FindFirstChild("NameLabel")
        if nameLabel and nameLabel:IsA("TextLabel") then
            if stripTags(nameLabel.Text):find("Coin Rain") then
                return "active", timeLeft
            end
        end

        -- event قادم (QE-*) — Title
        local titleLabel = ui:FindFirstChild("Title")
        if titleLabel and titleLabel:IsA("TextLabel") then
            if stripTags(titleLabel.Text):find("Coin Rain") then
                return "queued", timeLeft
            end
        end
    end

    return nil
end

-- ينتظر حتى يجي data في OnGoingTimers ثم يرجع الـ status
local function waitForCoinRainStatus(timeout)
    local deadline = tick() + (timeout or 15)
    while tick() < deadline do
        -- نوقف فوراً لو ضغط Stop
        if not getgenv().OxyoAutoHopCoin or getgenv().OxyoHopStopped then return nil end
        local ok, etc = pcall(function()
            return require(game:GetService("ReplicatedStorage").Modules.EventTimerController)
        end)
        if ok and etc and etc.OnGoingTimers and next(etc.OnGoingTimers) ~= nil then
            return getCoinRainStatus()
        end
        task.wait(1)
    end
    return nil
end

