local coinEventActive   = false
local coinCollectThread = nil

local nuclearStop

local _liveCoinParts  = {}
local _coinAddedConns = {}

local function startCoinTracker()
    for _, c in pairs(_coinAddedConns) do pcall(function() c:Disconnect() end) end
    _coinAddedConns = {}
    _liveCoinParts  = {}

    local function trackParent(parent)
        if not parent or not parent.Parent then return end
        local conn = parent.ChildAdded:Connect(function(obj)
            local lname = obj.Name:lower()
            if lname == "coin" or lname == "coinmodel" or lname == "coin_model" then
                local part
                if obj:IsA("BasePart") then
                    part = obj
                elseif obj:IsA("Model") then
                    task.wait()
                    part = obj.PrimaryPart or obj:FindFirstChildWhichIsA("BasePart")
                end
                if part then
                    _liveCoinParts[part] = true
                    obj.AncestryChanged:Connect(function()
                        if not obj.Parent then _liveCoinParts[part] = nil end
                    end)
                end
            end
        end)
        table.insert(_coinAddedConns, conn)
    end

    local gf = getGF()
    if gf then
        trackParent(gf)
        local folders = {"CoinRain","Coins","CoinFolder","Events"}
        for _, name in ipairs(folders) do
            local f = gf:FindFirstChild(name)
            if f then trackParent(f) end
        end
    end
    trackParent(workspace)
end

local function stopCoinTracker()
    for _, c in pairs(_coinAddedConns) do pcall(function() c:Disconnect() end) end
    _coinAddedConns = {}
    _liveCoinParts  = {}
end

local function findCoins()
    local coins = {}
    for part in pairs(_liveCoinParts) do
        if part and part.Parent then
            table.insert(coins, part)
        else
            _liveCoinParts[part] = nil
        end
    end
    return coins
end

local _coinHopDone    = false
local _coinHopPending = false

local function startCoinCollect()
    if coinCollectThread then task.cancel(coinCollectThread) coinCollectThread = nil end
    _coinHopDone    = false
    coinEventActive = true
    coinCollectThread = task.spawn(function()
        local deadline    = tick() + coinEventDuration
        local idleTicks   = 0
        while autoCoinEnabled and (not autoHopCoinEnabled or not getgenv().OxyoHopStopped) do
            local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if not root then task.wait(0.3) continue end

            local coins = findCoins()

            if #coins == 0 then
                idleTicks = idleTicks + 1
                if tick() > deadline and idleTicks > 6 then
                    break
                end
                task.wait(0.3)
                continue
            end

            idleTicks = 0
            deadline  = math.max(deadline, tick() + 8)

            table.sort(coins, function(a, b)
                local ra = root and (a.Position - root.Position).Magnitude or 0
                local rb = root and (b.Position - root.Position).Magnitude or 0
                return ra < rb
            end)

            for _, part in ipairs(coins) do
                if not autoCoinEnabled then break end
                if not part or not part.Parent then continue end
                root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                if not root then break end
                safeTeleport(CFrame.new(part.Position + Vector3.new(0, 3, 0)))
                task.wait(0.55)
            end
        end

        coinEventActive   = false
        coinCollectThread = nil

        pcall(function()
            local hum = player.Character and player.Character:FindFirstChildOfClass("Humanoid")
            local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if hum and root then
                hum.PlatformStand = false
                hum:ChangeState(Enum.HumanoidStateType.Running)
            end
        end)

        if autoHopCoinEnabled and autoCoinEnabled and not _coinHopDone and not getgenv().OxyoHopStopped then
            _coinHopDone    = true
            _coinHopPending = true
            Rayfield:Notify({ Title = "Auto Hop", Content = "Coin Rain ended — hopping...", Duration = 2, Image = 4483362458 })
            task.wait(1)
            if not getgenv().OxyoHopStopped and autoHopCoinEnabled then
                getgenv().OxyoAutoHopCoin = true
                task.spawn(smartHop)
            end
            _coinHopPending = false
        end
    end)
end

local _notifConnected = {}
local function _tryConnectNotif(remote)
    if _notifConnected[remote] then return end
    _notifConnected[remote] = true
    remote.OnClientEvent:Connect(function(msg)
        if type(msg) ~= "string" then return end
        local lower = msg:lower()
        if lower:find("coin") and (lower:find("rain") or lower:find("start") or lower:find("event")) then
            local secs = msg:match("(%d+)")
            coinEventDuration = tonumber(secs) or 90
            if autoCoinEnabled and not coinEventActive then
                Rayfield:Notify({ Title = "Coin Rain!", Content = "Started — farming!", Duration = 3, Image = 4483362458 })
                startCoinCollect()
            end
        end
    end)
end

task.spawn(function()
    local _notifPaths = {
        {"Events","Notification"},{"Remotes","Notification"},
        {"Events","CoinRain"},{"Remotes","CoinRain"},
        {"Events","SystemNotification"},{"Remotes","SystemNotification"},
    }
    for _, path in ipairs(_notifPaths) do
        pcall(function()
            local parent = ReplicatedStorage
            for i = 1, #path - 1 do
                local c = parent:FindFirstChild(path[i]) or parent:WaitForChild(path[i], 3)
                if not c then return end
                parent = c
            end
            local remote = parent:FindFirstChild(path[#path])
            if remote and remote:IsA("RemoteEvent") then _tryConnectNotif(remote) end
        end)
    end
end)

