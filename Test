local function smartHop()
    task.wait(3)
    if not getgenv().OxyoAutoHopCoin or getgenv().OxyoHopStopped then return end

    local ok, body = pcall(function()
        return game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Desc&limit=100")
    end)

    if ok and body then
        local ok2, data = pcall(function()
            return game:GetService("HttpService"):JSONDecode(body)
        end)
        if ok2 and data and data.data then
            local servers = {}
            for _, s in ipairs(data.data) do
                local isFull    = s.playing and s.maxPlayers and s.playing >= s.maxPlayers
                local isVisited = getgenv().OxyoVisitedServers[s.id]
                local isCurrent = s.id == game.JobId
                if s.id and not isFull and not isVisited and not isCurrent then
                    table.insert(servers, s.id)
                end
            end

            if #servers > 0 then
                local chosen = servers[math.random(1, #servers)]
                getgenv().OxyoVisitedServers[chosen] = true
                pcall(function()
                    game:GetService("TeleportService"):TeleportToPlaceInstance(game.PlaceId, chosen, player)
                end)
                return
            end
        end
    end

    -- fallback
    pcall(function()
        game:GetService("TeleportService"):Teleport(game.PlaceId, player)
    end)
end

do
    local mt           = getrawmetatable(game)
    local old_namecall = mt.__namecall
    local old_index    = mt.__index
    setreadonly(mt, false)
    mt.__namecall = newcclosure(function(self, ...)
        local method = getnamecallmethod()
        if method == "Kick" then return end
        if method == "FireServer" or method == "InvokeServer" then
            local args = {...}
            if typeof(args[1]) == "string" then
                local s = args[1]:lower()
                if s:find("kick") or s:find("ban") or s:find("anticheat") or
                   s:find("detect") or s:find("flag") or s:find("report") then
                    return
                end
            end
        end
        return old_namecall(self, ...)
    end)
    mt.__index = newcclosure(function(self, key)
        return old_index(self, key)
    end)
    setreadonly(mt, true)
end

