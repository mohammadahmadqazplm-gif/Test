GearTab:CreateToggle({
    Name         = "Auto Buy",
    CurrentValue = false,
    Flag         = "AutoBuyGear",
    Callback     = function(Value)
        autoBuyEnabled = Value
        if Value then
            if not selectedGear then
                Rayfield:Notify({ Title = "Auto Buy", Content = "Select a gear first!", Duration = 3, Image = 4483362458 })
                autoBuyEnabled = false
                return
            end
            local data = GEAR_REGISTRY[selectedGear]
            Rayfield:Notify({ Title = "Auto Buy", Content = "Watching for: " .. data.displayName, Duration = 3, Image = 4483362458 })

            autoBuyThread = task.spawn(function()
                -- نراقب GearsAccess — لما ينزل الـ gear نشتري فوراً
                local function isGearInShop()
                    local gf = workspace:FindFirstChild("GameFolder")
                    local ga = gf and gf:FindFirstChild("Shops")
                             and gf.Shops:FindFirstChild("Vendor")
                             and gf.Shops.Vendor:FindFirstChild("GearsAccess")
                    return ga ~= nil and #ga:GetChildren() > 0
                end

                -- الحالة الأولى — جرب فوراً
                local result = buyGear(selectedGear)

                if result == BUY_RESULT.SUCCESS then
                    autoBuyEnabled = false
                    return

                elseif result == BUY_RESULT.OUT_OF_STOCK then
                    -- ما في مخزون — نوقف وننبه
                    Rayfield:Notify({ Title = "Out of Stock", Content = data.displayName .. " is out of stock — Auto Buy stopped.", Duration = 5, Image = 4483362458 })
                    autoBuyEnabled = false
                    return

                elseif result == BUY_RESULT.NO_COINS then
                    -- ما في كوينز — كل 30 ثانية نحاول
                    Rayfield:Notify({ Title = "Not Enough Coins", Content = "Need " .. data.coinPrice .. " coins — retrying every 30s.", Duration = 4, Image = 4483362458 })
                    while autoBuyEnabled do
                        task.wait(30)
                        if not autoBuyEnabled then break end
                        local r = buyGear(selectedGear)
                        if r == BUY_RESULT.SUCCESS then
                            autoBuyEnabled = false
                            return
                        elseif r == BUY_RESULT.OUT_OF_STOCK then
                            Rayfield:Notify({ Title = "Out of Stock", Content = data.displayName .. " is out of stock — Auto Buy stopped.", Duration = 5, Image = 4483362458 })
                            autoBuyEnabled = false
                            return
                        elseif r == BUY_RESULT.NO_COINS then
                            Rayfield:Notify({ Title = "Still Not Enough Coins", Content = "Need " .. data.coinPrice .. " — retrying in 30s.", Duration = 3, Image = 4483362458 })
                        end
                    end

                elseif result == BUY_RESULT.NOT_IN_SHOP then
                    -- مو في الشوب — نراقب GearsAccess ونشتري لحظة ما ينزل
                    Rayfield:Notify({ Title = "Not in Shop", Content = "Watching for " .. data.displayName .. " to appear...", Duration = 4, Image = 4483362458 })

                    -- ننتظر حتى يظهر في GearsAccess
                    while autoBuyEnabled do
                        task.wait(1)
                        if not autoBuyEnabled then break end
                        if isGearInShop() then
                            -- نزل! نشتري فوراً
                            task.wait(0.2)
                            local r = buyGear(selectedGear)
                            if r == BUY_RESULT.SUCCESS then
                                autoBuyEnabled = false
                                return
                            elseif r == BUY_RESULT.OUT_OF_STOCK then
                                Rayfield:Notify({ Title = "Out of Stock", Content = data.displayName .. " is out of stock — Auto Buy stopped.", Duration = 5, Image = 4483362458 })
                                autoBuyEnabled = false
                                return
                            elseif r == BUY_RESULT.NO_COINS then
                                Rayfield:Notify({ Title = "Not Enough Coins", Content = "Need " .. data.coinPrice .. " coins — retrying every 30s.", Duration = 4, Image = 4483362458 })
                                -- نروح على loop الكوينز
                                while autoBuyEnabled do
                                    task.wait(30)
                                    local r2 = buyGear(selectedGear)
                                    if r2 == BUY_RESULT.SUCCESS then autoBuyEnabled = false return end
                                    if r2 == BUY_RESULT.OUT_OF_STOCK then
                                        Rayfield:Notify({ Title = "Out of Stock", Content = data.displayName .. " is out of stock — stopped.", Duration = 5, Image = 4483362458 })
                                        autoBuyEnabled = false
                                        return
                                    end
                                end
                            end
                        end
                    end
                end
            end)
        else
            if autoBuyThread then task.cancel(autoBuyThread) autoBuyThread = nil end
            Rayfield:Notify({ Title = "Auto Buy", Content = "Stopped.", Duration = 2, Image = 4483362458 })
        end
    end,
})

CheeseTab:CreateSection("Auto Cheese")

local function runAutoCheeseLoop()
    while autoCheeseEnabled do
        if cheeseEventBusy or _G.cheeseEventBusy then task.wait(0.1) continue end
        local gf = workspace:FindFirstChild("GameFolder")
        local cheeseFolder = gf and gf:FindFirstChild("CheeseFolder")
        if not cheeseFolder then task.wait(2) continue end
        local cheeses = cheeseFolder:GetChildren()
        if #cheeses == 0 then task.wait(1.5) continue end
        for _, cheeseModel in ipairs(cheeses) do
            if not autoCheeseEnabled then break end
            if cheeseEventBusy or _G.cheeseEventBusy then task.wait(0.1) break end
            if not cheeseModel or not cheeseModel.Parent then continue end
            local mainPart = cheeseModel:FindFirstChild("Main")
            if not mainPart or not mainPart:IsA("BasePart") then continue end
            local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if not root then task.wait(1) break end
            safeTeleport(CFrame.new(mainPart.Position + Vector3.new(0, 2, 0)))
            task.wait(0.35)
        end
        task.wait(0.5)
    end
end

