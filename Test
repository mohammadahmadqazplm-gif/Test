-- ===== NUCLEAR STOP — هنا بعد تعريف كل المتغيرات =====
-- nuclearStop forward declaration — تعريفها الحقيقي بعد hopToggleRef
local nuclearStop

local function startCoinCollect()
    if coinCollectThread then task.cancel(coinCollectThread) coinCollectThread = nil end
    coinCollectThread = task.spawn(function()
        local endTime = tick() + coinEventDuration
        while autoCoinEnabled and tick() < endTime do
            local root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
            if not root then task.wait(0.3) continue end

            local coins = {}
            for _, obj in pairs(workspace:GetChildren()) do
                if obj.Name == "Coin" and obj:IsA("Model") then
                    local part = obj:FindFirstChildWhichIsA("BasePart") or obj.PrimaryPart
                    if part then table.insert(coins, part) end
                end
            end

            if #coins == 0 then task.wait(0.2) continue end

            for _, part in ipairs(coins) do
                if not autoCoinEnabled or tick() >= endTime then break end
                if not part or not part.Parent then continue end
                root = player.Character and player.Character:FindFirstChild("HumanoidRootPart")
                if not root then break end
                root.CFrame = CFrame.new(part.Position + Vector3.new(0, 3, 0))
                task.wait(0.7)
            end
        end

        coinEventActive = false
        coinCollectThread = nil

        -- خلص الفارم — نهوب
        if autoHopCoinEnabled then
            Rayfield:Notify({ Title = "Auto Hop", Content = "Coin Rain ended — hopping...", Duration = 2, Image = 4483362458 })
            task.wait(1)
            getgenv().OxyoAutoHopCoin = true
            smartHop()
        end
    end)
end

