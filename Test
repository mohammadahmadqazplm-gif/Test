local function smartHop()
    task.wait(3)
    if not getgenv().OxyoAutoHopCoin or getgenv().OxyoHopStopped then return end

    local ok, body = pcall(function()
        return game:HttpGet("https://games.roblox.com/v1/games/" .. game.PlaceId .. "/servers/Public?sortOrder=Asc&limit=100")
    end)

    if ok and body then
        local ok2, data = pcall(function()
            return game:GetService("HttpService"):JSONDecode(body)
        end)
        if ok2 and data and data.data then
            local servers = {}
            for _, s in ipairs(data.data) do
                local isFull    = s.playing and s.maxPlayers and s.playing >= (s.maxPlayers - 2)
                local isVisited = getgenv().OxyoVisitedServers[s.id]
                local isCurrent = s.id == game.JobId
                if s.id and not isFull and not isVisited and not isCurrent then
                    table.insert(servers, s.id)
                end
            end

            if #servers > 0 then
                local chosen = servers[math.random(1, #servers)]
                getgenv().OxyoVisitedServers[chosen] = true
                pcall(function() Rayfield:SaveConfiguration() end)
                doTeleport(chosen)
                return
            end
        end
    end

    if not getgenv().OxyoAutoHopCoin or getgenv().OxyoHopStopped then return end
    Rayfield:Notify({ Title = "Auto Hop", Content = "No valid servers found — retrying...", Duration = 3, Image = 4483362458 })
    task.wait(5)
    if getgenv().OxyoAutoHopCoin and not getgenv().OxyoHopStopped then
        task.spawn(smartHop)
    end
end

