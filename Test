local function getCheeseSubmitPrompt()
    local gf = workspace:FindFirstChild("GameFolder")
    if not gf then return nil end
    local ev = gf:FindFirstChild("CheeseEvent")
    if not ev then return nil end
    local plat = ev:FindFirstChild("Platform")
    if not plat then return nil end
    local att = plat:FindFirstChild("SubmitAttachment")
    if att then
        local p = att:FindFirstChildWhichIsA("ProximityPrompt")
                  or att:FindFirstChild("Prompt")
        if p then return p end
    end
    return plat:FindFirstChildWhichIsA("ProximityPrompt", true)
end

local function getCheeseEventPos()
    local gf = workspace:FindFirstChild("GameFolder")
    if not gf then return nil end
    local ev = gf:FindFirstChild("CheeseEvent")
    if not ev then return nil end
    local plat = ev:FindFirstChild("Platform")
    if not plat then return nil end
    local bp = plat:FindFirstChildWhichIsA("BasePart") or (plat:IsA("BasePart") and plat)
    return bp and bp.Position
end

