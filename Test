local function buyGear(gearKey)
    local data = GEAR_REGISTRY[gearKey]
    if not data then return BUY_RESULT.NOT_IN_SHOP end

    local remote = ReplicatedStorage:FindFirstChild("VendorPurchase", true)
                or (ReplicatedStorage:FindFirstChild("Events") and ReplicatedStorage.Events:FindFirstChild("VendorPurchase"))
                or (ReplicatedStorage:FindFirstChild("Remotes") and ReplicatedStorage.Remotes:FindFirstChild("VendorPurchase"))
    if not remote then return BUY_RESULT.NOT_IN_SHOP end

    local backpack = player:FindFirstChild("Backpack")
    if not backpack then return BUY_RESULT.NOT_IN_SHOP end

    local received = false
    local conn = backpack.ChildAdded:Connect(function(v)
        if v:IsA("Tool") then received = true end
    end)

    auto.lastNotif = ""
    pcall(function()
        if remote:IsA("RemoteFunction") then
            remote:InvokeServer(data.serverKey)
        else
            remote:FireServer(data.serverKey)
        end
    end)

    local waited = 0
    while waited < 3 and not received do
        task.wait(0.1)
        waited = waited + 0.1
        if auto.lastNotif ~= "" then break end
    end
    conn:Disconnect()

    if received then
        Rayfield:Notify({ Title = "✅ Purchased!", Content = data.displayName, Duration = 3, Image = 4483362458 })
        return BUY_RESULT.SUCCESS
    end

    local notif = auto.lastNotif:lower()
    if notif:find("out of stock") or notif:find("stock") then
        return BUY_RESULT.OUT_OF_STOCK
    elseif notif:find("not enough") or notif:find("afford") or notif:find("coin") then
        return BUY_RESULT.NO_COINS
    end

    return BUY_RESULT.NOT_IN_SHOP
end

local function applyJumpFix(hum)
    if not hum then return end
    local function enforce()
        if hum.Health <= 0 then return end
        hum:SetStateEnabled(Enum.HumanoidStateType.Jumping, true)
        if not jumpEnabled and hum.JumpPower <= 0 then
            hum.JumpPower = 50
        end
    end
    enforce()
    hum:GetPropertyChangedSignal("JumpPower"):Connect(enforce)
end

